<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>CheatResearchBench</defName>
    <label>cheat research bench</label>
    <description>A god-tier research bench. Counts as a High-Tech bench and connects to the Cheat Multi-Analyzer.</description>
    <graphicData>
      <texPath>Things/Building/Production/ResearchBenchHiTech</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(5,3)</drawSize>
    </graphicData>
    <castEdgeShadows>true</castEdgeShadows>
    <staticSunShadow>true</staticSunShadow>
    <size>(3,2)</size>
    <designationCategory>Production</designationCategory>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <surfaceType>Item</surfaceType>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <statBases>
      <MaxHitPoints>5000</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Flammability>0</Flammability>
      <ResearchSpeedFactor>10.0</ResearchSpeedFactor>
    </statBases>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>1</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <!-- ВОТ ЭТОТ БЛОК ОТВЕЧАЕТ ЗА СВЯЗЬ -->
      <li Class="CompProperties_AffectedByFacilities">
        <linkableFacilities>
          <li>MultiAnalyzer</li> <!-- Ванильный -->
          <li>CheatMultiAnalyzer</li> <!-- Твой новый -->
        </linkableFacilities>
      </li>
    </comps>
    <building>
      <!-- Этот тег заставляет игру думать, что стол высокотехнологичный -->
      <spawnedConceptLearnOpportunity>BuildingsConstruction</spawnedConceptLearnOpportunity>
    </building>
  </ThingDef>

</Defs>
