<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="FurnitureBase">
    <defName>CheatEndTable</defName>
    <label>cheat end table</label>
    <description>
An outrageously beautiful bedside structure radiating excessive aesthetic value.

Instantly transforms any bedroom into a luxury suite and boosts room impressiveness far beyond reasonable limits.
</description>
<graphicData>
      <texPath>Things/Building/Furniture/EndTable</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shadowData>
        <volume>(0.3, 0.6, 0.3)</volume>
      </shadowData>
    </graphicData>
	<uiIconPath>Things/Building/Furniture/EndTable_south</uiIconPath>
    <statBases>
      <MaxHitPoints>1000</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Mass>5</Mass>
      <Flammability>0</Flammability>
      <Beauty>6000</Beauty>
    </statBases>
    
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>20</costStuffCount>
    
    <size>(1,1)</size>
    <fillPercent>0.20</fillPercent>
    <pathCost>1</pathCost>
    <passability>PassThroughOnly</passability>
    <canOverlapZones>false</canOverlapZones>
    <designationCategory>Furniture</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    
    <comps>
      <li Class="CompProperties_Facility">
        <maxSimultaneous>1</maxSimultaneous>
      </li>
    </comps>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
  </ThingDef>

</Defs>