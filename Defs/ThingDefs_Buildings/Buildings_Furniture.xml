<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="Bed">
    <defName>CheatBed_Single</defName>
    <label>cheat bed</label>
    <description>A heavily modified sleep platform engineered for absolute biological optimization.</description>
    <graphicData>
      <texPath>VI/Furniture/Bed</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.5,2.5)</drawSize>
    </graphicData>
    <uiIconPath>VI/Furniture/Bed</uiIconPath>
    <tickerType>Rare</tickerType>
    <size>(1,2)</size>
    <statBases>
      <MaxHitPoints>5000</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Flammability>0</Flammability>
      <Beauty>100</Beauty>
      <Comfort>100</Comfort>
      <BedRestEffectiveness>100</BedRestEffectiveness>
      <ImmunityGainSpeedFactor>100</ImmunityGainSpeedFactor>
      <SurgerySuccessChanceFactor>2.0</SurgerySuccessChanceFactor>
    </statBases>
    <comps>
      <li Class="DivineBedMod.CompProperties_CheatBed" />
    </comps>
    <designationCategory>Furniture</designationCategory>
  </ThingDef>

  <ThingDef ParentName="DoubleBed">
    <defName>CheatBed_Double</defName>
    <label>double cheat bed</label>
    <description>A dual-occupancy version of the overpowered biological recovery platform.</description>
    <graphicData>
      <texPath>VI/Furniture/DoubleBed</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2.5,2.5)</drawSize>
    </graphicData>
    <tickerType>Rare</tickerType>
    <uiIconPath>VI/Furniture/DoubleBed</uiIconPath>
    <size>(2,2)</size>
    <statBases>
      <MaxHitPoints>8000</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Flammability>0</Flammability>
      <Beauty>200</Beauty>
      <Comfort>100</Comfort>
      <BedRestEffectiveness>100</BedRestEffectiveness>
      <ImmunityGainSpeedFactor>100</ImmunityGainSpeedFactor>
      <SurgerySuccessChanceFactor>2.0</SurgerySuccessChanceFactor>
    </statBases>
    <comps>
      <li Class="DivineBedMod.CompProperties_CheatBed" />
    </comps>
    <designationCategory>Furniture</designationCategory>
  </ThingDef>

</Defs>